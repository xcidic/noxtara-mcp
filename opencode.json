{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "noxtara": {
      "type": "local",
      "command": ["pnpm", "run", "start:mcp"],
      "enabled": true,
      "timeout": 60000,
      "environment": {
        "NOXTARA_API_BASE_URL": "{env:NOXTARA_API_BASE_URL}",
        "NOXTARA_PAT": "{env:NOXTARA_PAT}"
      }
    }
  }
}
