{
  "name": "pkg-placeholder",
  "version": "0.0.1",
  "description": "_description_",
  "keywords": [
    "pkg-placeholder"
  ],
  "homepage": "https://github.com/ericc-ch/pkg-placeholder",
  "bugs": "https://github.com/ericc-ch/pkg-placeholder/issues",
  "author": {
    "name": "Erick Christian",
    "email": "erickchristian48@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ericc-ch/pkg-placeholder.git"
  },
  "bin": {
    "pkg-placeholder": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "specs",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:openapi": "node scripts/generate-openapi.ts",
    "build": "pnpm run generate:openapi && tsdown",
    "format": "oxfmt",
    "lint": "oxlint --type-aware",
    "check": "pnpm run typecheck && pnpm run test && pnpm run lint",
    "prepare": "simple-git-hooks && effect-language-service patch && node scripts/references.ts",
    "prepack": "pnpm run build",
    "release": "bumpp && npm publish",
    "start": "node src/cli.ts",
    "mcp": "node src/cli.ts mcp",
    "mcp-http": "node src/cli.ts mcp-http",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@effect/platform-node": "^4.0.0-beta.65",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "effect": "^4.0.0-beta.65",
    "openapi-types": "^12.1.3",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "^4.0.0-beta.65",
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "@types/node": "24.x.x",
    "@usebruno/lang": "file:submodules/bruno/packages/bruno-lang",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run format",
    "pre-push": "pnpm run check"
  },
  "packageManager": "pnpm@11.1.0"
}
